{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "shell:allow-open",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "/home/l/subscriptions" },
        { "path": "/home/l/subscriptions/*" }
      ]
    }
  ]
}
