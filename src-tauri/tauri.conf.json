{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Subscription Tracker",
  "version": "0.1.0",
  "identifier": "com.openclaw.subscription.tracker",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Subscription Tracker",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
